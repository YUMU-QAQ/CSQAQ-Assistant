# CSQAQ API Configuration
CSQAQ_API_TOKEN=your_api_token_here
CSQAQ_BASE_URL=https://api.csqaq.com

# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your_claude_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./csqaq.db

# Feishu Bot Configuration (https://open.feishu.cn)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFY_TOKEN=your_feishu_verify_token
